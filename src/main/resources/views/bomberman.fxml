<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="omut.javafx.apps.controllers.BombermanController">

    <Canvas fx:id="canvas" width="600" height="440"/>

    <StackPane fx:id="overlay" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox alignment="CENTER" spacing="20">
            <Label fx:id="gameOverLabel" text="GAME OVER"
                   textFill="RED" style="-fx-font-size: 48px;" alignment="CENTER"/>
            <Button fx:id="startButton" text="Restart" onAction="#restartGame"/>
        </VBox>
    </StackPane>

</StackPane>