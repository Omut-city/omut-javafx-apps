            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="omut.javafx.apps.controllers.JavaFx3DController">

    <children>
        <AnchorPane fx:id="subScenePane" prefHeight="600.0" prefWidth="800.0" />
