<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="omut.javafx.apps.controllers.Base64EncoderDecoderController">

    <top>
        <MenuBar>
            <menus>
                <Menu text="%menu.file">
                    <items>
                        <MenuItem text="%menu.file.exit" onAction="#onExit"/>
                    </items>
                </Menu>
                <Menu text="%menu.about">
                    <items>
                        <MenuItem text="%menu.about.about" onAction="#onAbout"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <HBox spacing="10" alignment="CENTER" BorderPane.alignment="CENTER">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="%base64.input"/>
                    <TextArea fx:id="inputArea" promptText="%base64.prompt.input"
                              wrapText="true" VBox.vgrow="ALWAYS"/>
                </children>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="%base64.result"/>
                    <TextArea fx:id="outputArea" promptText="%base64.prompt.result"
                              wrapText="true" editable="false" VBox.vgrow="ALWAYS"/>
                </children>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="8" BorderPane.alignment="CENTER">
            <padding><Insets top="8" bottom="8"/></padding>

            <Button text="%base64.encode" onAction="#encodeInput"/>
            <Button text="%base64.decode" onAction="#decodeInput"/>
            <Button text="%base64.swap" onAction="#swapAreas"/>
            <Button text="%base64.copy" onAction="#copyOutput"/>
            <Button text="%base64.clear" onAction="#clearAll"/>

        </HBox>
    </bottom>

</BorderPane>