<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="omut.javafx.apps.controllers.TetrisController">

    <center>
        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 10;">
            <Canvas fx:id="canvas" width="300" height="600"/>

            <VBox spacing="15" alignment="TOP_CENTER" style="-fx-padding: 10;">
                <Label fx:id="scoreLabel" text="Score: 0" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="levelLabel" text="Level: 1" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="linesLabel" text="Lines: 0" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <VBox spacing="10" style="-fx-padding: 15; -fx-border-color: #cccccc; -fx-border-radius: 5;">
                    <Label fx:id="controlsLabel" text="Controls" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label fx:id="leftLabel" text="← LEFT: Move left" style="-fx-font-size: 12px;"/>
                    <Label fx:id="rightLabel" text="→ RIGHT: Move right" style="-fx-font-size: 12px;"/>
                    <Label fx:id="downLabel" text="↓ DOWN: Drop faster" style="-fx-font-size: 12px;"/>
                    <Label fx:id="dropLabel" text="SPACE: Drop to bottom" style="-fx-font-size: 12px;"/>
                    <Label fx:id="rotateLabel" text="↑ UP: Rotate" style="-fx-font-size: 12px;"/>
                </VBox>

                <VBox spacing="10">
                    <Button fx:id="startButton" text="New Game" onAction="#startGame"
                            style="-fx-font-size: 14px; -fx-padding: 10px;"/>
                    <Button fx:id="pauseButton" text="Pause" onAction="#togglePause"
                            style="-fx-font-size: 14px; -fx-padding: 10px;" disable="true"/>
                </VBox>
            </VBox>
        </HBox>
    </center>

</BorderPane>
